# ========== MONGODB CONFIGURATION ==========
# Production MongoDB Atlas - LolCluster
# Connection string includes credentials, connection pooling, and app name
MONGODB_URI=mongodb+srv://mroverx:ankit5639@slydata.qhj9lue.mongodb.net/slyxy?appName=SlyDATA

# ========== CORS ALLOWED ORIGINS ==========
# Comma-separated list of origins allowed by the backend CORS policy
# Add your frontend host(s) here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5000,http://127.0.0.1:3000,http://127.0.0.1:8080,http://127.0.0.1:5000,http://13.207.92.133:3000,http://13.207.92.133:8080,http://13.207.92.133:5000
ALLOW_LOCALHOST_CORS=true

# ========== SERVER CONFIGURATION ==========
# Server port
PORT=8080

# Server IP (advertised to clients)
SERVER_IP=127.0.0.1

# Server bind address (0.0.0.0 = all interfaces)
SERVER_BIND=0.0.0.0

# ========== OPTIONAL: TURN SERVER (for WebRTC) ==========
# Uncomment and configure if using external TURN server
# TURN_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=username
# TURN_CREDENTIAL=password

# ========== NODE ENVIRONMENT ==========
# development | production | staging
NODE_ENV=development

# ========== AWS / DynamoDB SETTINGS ========== 
AWS_REGION=ap-south-1
AWS_DEFAULT_REGION=ap-south-1
DYNAMODB_TABLE=oververseDB
AWS_DYNAMODB_TABLE=oververseDB
DYNAMODB_REGION=ap-south-1

# AWS S3 configuration for profile image uploads
AWS_S3_BUCKET=slyxy-buckets
AWS_S3_PROFILE_FOLDER=user
# AWS_S3_PUBLIC_URL=https://your-cloudfront-or-custom-domain

