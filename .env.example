# ========== MONGODB CONFIGURATION ==========
# Local MongoDB recommended for development
MONGODB_URI=mongodb://localhost:27017/slyxycluster

# For production, configure a hosted MongoDB URI in .env
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ========== CORS CONFIGURATION ==========
# Comma-separated allowed origins for frontend and API access
ALLOWED_ORIGINS=http://localhost:3000,http://13.207.92.133:8080

# ========== SERVER CONFIGURATION ==========
PORT=8080
SERVER_IP=127.0.0.1
SERVER_BIND=0.0.0.0

# ========== OPTIONAL: TURN SERVER (for WebRTC) ==========
# TURN_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=username
# TURN_CREDENTIAL=password

# ========== NODE ENVIRONMENT ==========
NODE_ENV=development
# ========== SMTP EMAIL SETTINGS (OTP DELIVERY) ===========
# For Gmail app passwords, use SMTP_USER and SMTP_PASS with an app password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=youremail@gmail.com
SMTP_PASS=your-email-app-password
SMTP_FROM="SLYXY <youremail@gmail.com>"
OTP_EXPIRE_SECONDS=300
OTP_EMAIL_SUBJECT=Your SLYXY verification code
